import Mathlib

/-!
# Uniqueness in the universal property of the Jacobian (Albanese)

Tower C.  Hole 9 (`Jacobian.exists_unique_ofCurve_comp`) asserts that a pointed
morphism `f : C ‚ü∂ A` from a curve to an abelian variety factors **uniquely** through
the Jacobian as a homomorphism `g` with `f = ofCurve P ‚â´ g`.  Round 1 supplied the
*existence-side rigidity* input (`isMonHom_of_pointed_of_geometricallyIntegral`: the
factoring map is forced to be a homomorphism).  This file supplies the **uniqueness**
half as ready-to-wire abelian-variety theory.

The mechanism is classical (Milne, *Jacobian Varieties* ¬ß6; Mumford, *Abelian
Varieties* ¬ß4): a homomorphism out of the Jacobian is determined by its composite with
the Abel‚ÄìJacobi map, because the iterated sums of that map generate the Jacobian.  We
formalize it as two genuine, general pieces and assemble them:

* `hom_ext_of_isDominant` ‚Äî **a morphism of `k`-schemes is determined by its restriction
  to a (topologically) dominant subscheme**, when the source is reduced and the target is
  separated over `k`.  For abelian varieties (target proper ‚üπ separated, source integral
  ‚üπ reduced) this is the uniqueness engine.  *Discharged on arbitrary data.*
* `postcompHom` ‚Äî **postcomposition by a homomorphism of group objects is a group
  homomorphism `Hom(W, J) ‚Üí* Hom(W, A)` of Hom-groups** (`MonObj.one_comp` /
  `MonObj.mul_comp`), so it carries finite sums of the Abel‚ÄìJacobi map to finite sums of
  its composite.  *Discharged on arbitrary data.*
* `albanese_uniqueness` ‚Äî assembles the two: if the iterated sums of `œÜ` generate `J`
  (the geometric *generation* input, supplied by Tower B as a dominant sum-morphism),
  then two homomorphisms agreeing after `œÜ` are equal.

The only input not discharged here is the genuine geometric fact that the curve generates
the Jacobian (`IsDominant` of an iterated-sum morphism) ‚Äî Tower B's `Jacobian C = Pic‚Å∞ C`
and `ofCurve` instantiate it; the integrator wires it.

No `sorry`, no `axiom`.
-/

open CategoryTheory Limits MonoidalCategory CartesianMonoidalCategory MonObj

namespace AbelianVariety

universe u

open AlgebraicGeometry

variable {K : Type u} [Field K]

/-! ### Determination of a morphism by a dominant subscheme -/

/-- **A morphism of `k`-schemes is determined by its restriction to a (topologically)
dominant subscheme**, when the source `J` is reduced and the target `A` is separated over
`k` (e.g. proper).  This is the uniqueness mechanism of the Albanese universal property:
the source is the Jacobian (an integral variety, hence reduced) and the target is an
abelian variety (proper, hence separated). -/
theorem hom_ext_of_isDominant {J A : Over (Spec (.of K))} [IsReduced J.left] [IsProper A.hom]
    {W : Over (Spec (.of K))} (u : W ‚ü∂ J) [IsDominant u.left]
    {g‚ÇÅ g‚ÇÇ : J ‚ü∂ A} (h : u ‚â´ g‚ÇÅ = u ‚â´ g‚ÇÇ) : g‚ÇÅ = g‚ÇÇ := by
  refine Over.OverMorphism.ext (ext_of_isDominant_of_isSeparated A.hom ?_ u.left ?_)
  ¬∑ rw [Over.w, Over.w]
  ¬∑ rw [‚Üê Over.comp_left, ‚Üê Over.comp_left, h]

/-! ### Postcomposition by a homomorphism is a homomorphism of Hom-groups -/

variable {M N : Over (Spec (.of K))} [MonObj M] [MonObj N]

/-- **Postcomposition by a homomorphism of group (monoid) objects is a monoid
homomorphism of Hom-groups** `Hom(W, M) ‚Üí* Hom(W, N)`.  Concretely `a ‚Ü¶ a ‚â´ g`; it
preserves the identity (`MonObj.one_comp`) and the product (`MonObj.mul_comp`), so it
sends a finite sum `‚àè·µ¢ a·µ¢` to `‚àè·µ¢ (a·µ¢ ‚â´ g)`. -/
@[simps]
noncomputable def postcompHom (g : M ‚ü∂ N) [IsMonHom g] (W : Over (Spec (.of K))) :
    (W ‚ü∂ M) ‚Üí* (W ‚ü∂ N) where
  toFun a := a ‚â´ g
  map_one' := MonObj.one_comp g
  map_mul' a b := MonObj.mul_comp a b g

/-! ### Uniqueness in the Albanese universal property -/

variable {C J A : Over (Spec (.of K))} [GrpObj J] [GrpObj A] [IsCommMonObj J] [IsCommMonObj A]

/-- **Uniqueness in the Albanese universal property.**  Let `œÜ : C ‚ü∂ J` be the
Abel‚ÄìJacobi map of a curve `C` into an abelian variety `J`, and suppose the iterated sums
of `œÜ` *generate* `J`: for some finite family `c : Fin n ‚Üí (W ‚ü∂ C)` the sum-morphism
`‚àè·µ¢ (c i ‚â´ œÜ) : W ‚ü∂ J` is (topologically) dominant.  (This is the geometric content that
the Jacobian is generated by the curve ‚Äî the Tower-B input; the integrator instantiates
`W = C‚Åø`, `c = projections`, dominance from Jacobi inversion / Riemann‚ÄìRoch.)  Then any
two group homomorphisms `g‚ÇÅ g‚ÇÇ : J ‚ü∂ A` to an abelian variety `A` that agree after `œÜ` are
equal. -/
theorem albanese_uniqueness [IsReduced J.left] [IsProper A.hom]
    (œÜ : C ‚ü∂ J) {g‚ÇÅ g‚ÇÇ : J ‚ü∂ A} [IsMonHom g‚ÇÅ] [IsMonHom g‚ÇÇ]
    (hœÜ : œÜ ‚â´ g‚ÇÅ = œÜ ‚â´ g‚ÇÇ)
    {n : ‚Ñï} {W : Over (Spec (.of K))} (c : Fin n ‚Üí (W ‚ü∂ C))
    (hdom : IsDominant (‚àè i, c i ‚â´ œÜ).left) : g‚ÇÅ = g‚ÇÇ := by
  haveI := hdom
  refine hom_ext_of_isDominant (‚àè i, c i ‚â´ œÜ) ?_
  have key : ‚àÄ i : Fin n, (c i ‚â´ œÜ) ‚â´ g‚ÇÅ = (c i ‚â´ œÜ) ‚â´ g‚ÇÇ := fun i => by
    rw [Category.assoc, Category.assoc, hœÜ]
  have e‚ÇÅ := map_prod (postcompHom g‚ÇÅ W) (fun i => c i ‚â´ œÜ) Finset.univ
  have e‚ÇÇ := map_prod (postcompHom g‚ÇÇ W) (fun i => c i ‚â´ œÜ) Finset.univ
  simp only [postcompHom_apply] at e‚ÇÅ e‚ÇÇ
  rw [e‚ÇÅ, e‚ÇÇ]
  exact Finset.prod_congr rfl (fun i _ => key i)

end AbelianVariety
